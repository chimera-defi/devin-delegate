{
  "version": "0.2.4",
  "provider": "devin",
  "model": "devin-default",
  "timeout_seconds": 300,
  "max_output_tokens": 2000,
  "max_retries": 1,
  "fallback_engine": "claude",
  "fallback_provider": "anthropic",
  "fallback_model": "claude-sonnet-4-6",
  "fallback_providers": {
    "codex": {
      "enabled": true,
      "default_model": "gpt-5.5",
      "priority": 1
    },
    "kimi": {
      "enabled": false,
      "default_model": "kimi-default",
      "priority": 2,
      "_note": "Kimi quota exhausted 2026-05-28; re-enable when quota resets"
    },
    "anthropic": {
      "enabled": true,
      "default_model": "claude-sonnet-4-6",
      "priority": 3
    },
    "pi": {
      "enabled": true,
      "default_model": "gpt-5.3-codex",
      "priority": 4
    }
  },
  "fallback_strategy": "priority",
  "auto_context_enabled": true,
  "auto_context_history_limit": 5,
  "auto_context_max_chars": 4000,
  "max_timeout_seconds": 600,
  "large_repo_threshold_files": 10000,
  "large_repo_threshold_mb": 500,
  "large_repo_timeout_multiplier": 2.0,
  "xlarge_repo_threshold_files": 50000,
  "xlarge_repo_threshold_mb": 1000,
  "xlarge_repo_timeout_multiplier": 3.0,
  "workspace_default": "/home/agents/workspace"
}
